rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      // TODO(V1): Admin access should be granted via a custom claim (e.g. `admin == true`)
      // set by backend using the `ALLOWED_ADMIN_EMAILS` allowlist.
      return request.auth != null && request.auth.token.admin == true;
    }

    match /{document=**} {
      // V1 internal-only: clients are denied unless explicitly admin.
      allow read, write: if isAdmin();
    }
  }
}

