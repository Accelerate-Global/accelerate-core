# Shared
GOOGLE_CLOUD_PROJECT=accelerate-global-473318
FIREBASE_PROJECT_ID=accelerate-global-473318
BIGQUERY_DATASET=accelerate_dev
BIGQUERY_LOCATION=US

# GCS buckets must be globally unique. Prefer appending "-473318" if the base name is taken.
ARTIFACTS_BUCKET=accelerate-artifacts-dev

# V1 internal-only admin allowlist (exact emails, comma-separated)
ALLOWED_ADMIN_EMAILS=email1@example.com,email2@example.com

# API -> worker (Cloud Run)
# Cloud Run worker base URL (no trailing slash). Required for POST /runs to auto-kickoff the worker.
WORKER_BASE_URL=https://<worker-cloud-run-url>

# Worker auth mode:
# - iam: Cloud Run IAM auth + X-Accelerate-Actor-Email header (default)
# - firebase: Authorization: Bearer <Firebase ID token>
WORKER_AUTH_MODE=iam

# Dev-only escape hatch (skips Firebase token verification when NODE_ENV!=production)
DEV_AUTH_EMAIL=

# Connector secrets (set via Secret Manager at deploy)
JOSHUA_PROJECT_API_KEY= # (set via Secret Manager at deploy)
JOSHUA_PROJECT_BASE_URL=
JOSHUA_PROJECT_LIMIT=
JOSHUA_PROJECT_MAX_PAGES=

# Web (Firebase client config)
# Server-side (preferred): keeps base URL out of client bundles.
API_BASE_URL=
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=accelerate-global-473318
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional: used only to hide/show admin UI in web (API/Worker remain the enforcement point).
# Note this value is public if used (NEXT_PUBLIC_*).
NEXT_PUBLIC_ALLOWED_ADMIN_EMAILS=
