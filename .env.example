# Supabase project URL used in local, preview, and production environments.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Public anonymous key used by browser and server-rendered auth clients.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only service role key for future admin workflows. Never expose this in the browser.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Public application URL.
# Local development: http://localhost:3000
# Vercel production: set this explicitly to https://data.accelerateglobal.org
# Non-production Vercel hosts are acceptable only for preview-specific testing.
# Do not rely on deployment URL fallback for production auth redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin-only Phase 8 experiment gates. Keep these disabled until human review is complete.
EXPERIMENTS_ADMIN_ENABLED=false
EXPERIMENTS_TEXT_TO_QUERY_ENABLED=false

# Phase 8 scaffolding-only provider references. These stay informational until real providers and governance are approved.
EXPERIMENT_WAREHOUSE_PROVIDER=
EXPERIMENT_WAREHOUSE_CONNECTION_REFERENCE=
EXPERIMENT_TEXT_TO_QUERY_PROVIDER=
EXPERIMENT_TEXT_TO_QUERY_ALLOWLIST_DATASET_IDS=
EXPERIMENT_TEXT_TO_QUERY_LOG_REFERENCE=

# Server-only Google Workspace service account JSON used for read-only Sheet validation.
# Store the exact downloaded JSON document in one secret value.
GOOGLE_WORKSPACE_SERVICE_ACCOUNT_JSON=

# Spreadsheet id for the first Google Workspace source.
GOOGLE_WORKSPACE_SOURCE_SPREADSHEET_ID=

# Optional sheet/tab name. If omitted, the first sheet in the spreadsheet is used.
GOOGLE_WORKSPACE_SOURCE_SHEET_NAME=

# Optional A1 range for preview reads. If omitted, the app previews a bounded default range.
# If provided without a sheet prefix, the resolved sheet/tab name is applied automatically.
GOOGLE_WORKSPACE_SOURCE_RANGE=
